<Window x:Class="WindowsHUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows HUD"
        Icon="Assets/app.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Border x:Name="RootBorder"
            Background="#B2202020"
            CornerRadius="8"
            Padding="10,6">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="CpuText" Foreground="White" FontSize="13" FontFamily="Consolas" Text="CPU --%" VerticalAlignment="Center"/>
            <TextBlock Text="   " Foreground="White"/>
            <TextBlock x:Name="GpuText" Foreground="White" FontSize="13" FontFamily="Consolas" Text="GPU --%" VerticalAlignment="Center"/>
            <TextBlock Text="   " Foreground="White"/>
            <TextBlock x:Name="MemText" Foreground="White" FontSize="13" FontFamily="Consolas" Text="MEM --%" VerticalAlignment="Center"/>
            <TextBlock Text="   " Foreground="White"/>
            <TextBlock x:Name="NetText" Foreground="White" FontSize="13" FontFamily="Consolas" Text="↓0.0MB/s ↑0.0MB/s" VerticalAlignment="Center"/>
            <TextBlock Text="   " Foreground="White"/>
            <TextBlock x:Name="DiskText" Foreground="White" FontSize="13" FontFamily="Consolas" Text="DISK --%" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
